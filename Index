// ===== DAY-OF-WEEK SUGGESTION =====
// Mon=strength · Tue=cardio · Wed=maintenance · Thu=cardio · Fri=strength · Sat=adventure · Sun=maintenance
const DOW_DAYTYPE=['maintenance','strength','cardio','maintenance','cardio','strength','adventure'];
function suggestedDayType(){return DOW_DAYTYPE[dayOfWeek()];}
const DAYTYPE_LABELS={strength:'Strength Push',cardio:'Cardio Push',adventure:'Adventure',maintenance:'Maintenance',travel:'Travel'};

// ===== STATE =====
let currentRecovery=null,currentDayType=null,currentSessionType='training',currentMode='prescribed';
const MAINT_CAP=2;


// ===== TODAY DATA HELPERS =====
function loadTodayWorkout(){return loadRecords('workouts').find(r=>r.date===todayStr())||null;}
function loadTodayRecovery(){return loadRecords('recovery').find(r=>r.date===todayStr())||null;}
function maintenanceUsedThisWeek(){return loadRecords('workouts').filter(w=>w.sessionType==='maintenance'&&dateInThisWeek(w.date)&&(w.completed||0)>0).length;}
function pushDaysThisWeek(){return loadRecords('workouts').filter(w=>w.sessionType!=='maintenance'&&w.recovery!=='travel'&&dateInThisWeek(w.date)&&(w.completed||0)>0).length;}
function calculateStreak(){
  const recs=loadRecords('workouts').filter(w=>(w.completed||0)>0);
  if(recs.length===0)return 0;
  const dates=new Set(recs.map(r=>r.date));
  let streak=0,cursor=new Date();
  for(let i=0;i<365;i++){
    const d=cursor.toISOString().slice(0,10);
    if(dates.has(d))streak++;
    else if(i>0)break;
    cursor.setDate(cursor.getDate()-1);
  }
  return streak;
}

