<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#5d7a5a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="VESPER">
<title>VESPER</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --sage-deep:#5d7a5a; --sage:#7d9778; --eucalyptus:#a4b8a0; --sage-pale:#d6e0d2;
  --cream:#faf6ed; --parchment:#f0ead9; --bone:#fbf8f1;
  --rose-dust:#c8a4a4; --rose-pale:#e6cccc;
  --brass:#a88542; --brass-deep:#8a6a30; --brass-pale:#d9c08a;
  --ink:#1f1f1c; --ink-soft:#2e2e28; --muted:#5e5b50; --muted-strong:#3f3d36;
  --card:rgba(255,252,244,0.78); --border:rgba(125,151,120,0.18); --border-strong:rgba(93,122,90,0.32);
  --green:#5d7a5a; --amber:#b8923f; --red:#9a4f4f; --travel:#6b829a;
  --t-foundation:#a3a09a; --t-solid:#8d9b87; --t-strong:#5d7a5a; --t-decathlon:#a88542; --t-centenarian:#8a6a30;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{overflow-x:hidden;}
body{background:var(--cream);font-family:'DM Mono',monospace;color:var(--ink);min-height:100vh;padding-bottom:90px;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 70% 50% at 5% 15%,rgba(164,184,160,0.28) 0%,transparent 60%),radial-gradient(ellipse 50% 70% at 95% 85%,rgba(200,164,164,0.18) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 50% 50%,rgba(217,192,138,0.08) 0%,transparent 70%);pointer-events:none;z-index:0;}
.app{position:relative;z-index:1;max-width:560px;margin:0 auto;padding:1.5rem 1.25rem 2rem;}
header{text-align:center;margin-bottom:1.5rem;}
.wordmark{font-family:'Cormorant Garamond',serif;font-size:2.75rem;font-weight:300;letter-spacing:0.4em;color:var(--sage-deep);line-height:1;text-indent:0.4em;}
.tagline{font-size:0.58rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--muted-strong);margin-top:0.55rem;font-weight:500;}
.card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.25rem;margin-bottom:1rem;backdrop-filter:blur(12px);box-shadow:0 2px 20px rgba(93,122,90,0.05);}
.label{font-size:0.55rem;letter-spacing:0.32em;text-transform:uppercase;color:var(--muted-strong);margin-bottom:0.75rem;font-weight:500;}
h2{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:400;color:var(--sage-deep);margin-bottom:0.6rem;}
p{font-size:0.78rem;line-height:1.65;color:var(--ink-soft);font-weight:400;}
.checkin-banner{background:linear-gradient(135deg,rgba(168,133,66,0.15),rgba(217,192,138,0.12));border:1px solid rgba(168,133,66,0.35);border-radius:14px;padding:1rem 1.1rem;margin-bottom:1rem;display:none;}
.checkin-banner.show{display:block;}
.checkin-title{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--brass-deep);margin-bottom:0.3rem;}
.checkin-text{font-size:0.7rem;color:var(--ink-soft);line-height:1.55;margin-bottom:0.75rem;font-weight:400;}
.checkin-actions{display:flex;gap:0.5rem;}
.checkin-actions button{flex:1;background:rgba(255,252,244,0.7);border:1px solid rgba(168,133,66,0.35);border-radius:10px;padding:0.55rem;font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--brass-deep);cursor:pointer;}
.checkin-actions button.primary{background:var(--brass);color:white;border-color:var(--brass);}
.tabbar{position:fixed;bottom:0;left:0;right:0;background:rgba(250,246,237,0.95);backdrop-filter:blur(14px);border-top:1px solid var(--border-strong);display:flex;justify-content:space-around;padding:0.6rem 0.5rem calc(0.6rem + env(safe-area-inset-bottom));z-index:100;}
.tab{flex:1;background:none;border:none;font-family:'DM Mono',monospace;font-size:0.58rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted-strong);padding:0.5rem 0.3rem;cursor:pointer;border-radius:10px;transition:all 0.2s;font-weight:500;}
.tab.active{color:var(--sage-deep);background:rgba(164,184,160,0.22);}
.tab-icon{display:block;font-size:1.1rem;margin-bottom:0.25rem;font-family:'Cormorant Garamond',serif;font-weight:400;}
.view{display:none;animation:fade 0.3s ease;}
.view.active{display:block;}
@keyframes fade{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.recovery-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0.45rem;margin-top:0.7rem;}
.rec-btn{border:1.5px solid transparent;border-radius:14px;padding:0.85rem 0.3rem;font-family:'DM Mono',monospace;background:rgba(255,252,244,0.55);cursor:pointer;text-align:center;transition:all 0.2s;}
.rec-btn.green{border-color:rgba(93,122,90,0.3);}
.rec-btn.yellow{border-color:rgba(184,146,63,0.3);}
.rec-btn.red{border-color:rgba(154,79,79,0.25);}
.rec-btn.travel{border-color:rgba(107,130,154,0.3);}
.rec-btn.green.selected{background:rgba(93,122,90,0.15);border-color:var(--green);}
.rec-btn.yellow.selected{background:rgba(184,146,63,0.15);border-color:var(--amber);}
.rec-btn.red.selected{background:rgba(154,79,79,0.12);border-color:var(--red);}
.rec-btn.travel.selected{background:rgba(107,130,154,0.15);border-color:var(--travel);}
.rec-dot{width:11px;height:11px;border-radius:50%;margin:0 auto 0.4rem;}
.rec-btn.green .rec-dot{background:var(--green);}
.rec-btn.yellow .rec-dot{background:var(--amber);}
.rec-btn.red .rec-dot{background:var(--red);}
.rec-btn.travel .rec-dot{background:var(--travel);}
.rec-name{font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink);font-weight:600;}
.rec-sub{font-size:0.54rem;color:var(--muted-strong);margin-top:0.25rem;font-weight:500;}
.primer{background:linear-gradient(135deg,rgba(164,184,160,0.2),rgba(217,192,138,0.12));border:1px solid var(--border-strong);border-radius:14px;padding:1.1rem 1.2rem;margin-top:0.7rem;}
.primer-text{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-style:italic;line-height:1.55;color:var(--sage-deep);font-weight:400;}
.workout-meta{display:flex;justify-content:space-between;align-items:center;padding:0.55rem 0.75rem;background:rgba(164,184,160,0.18);border-radius:8px;margin-bottom:0.8rem;font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted-strong);font-weight:500;}
.workout-swap-btn{background:transparent;border:1px solid var(--border-strong);color:var(--sage-deep);border-radius:6px;padding:0.3rem 0.6rem;font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.15em;cursor:pointer;}
.daytype-row{margin-bottom:1rem;padding:0.7rem 0.85rem;background:rgba(164,184,160,0.1);border:1px solid var(--border);border-radius:12px;}
.daytype-label{font-size:0.55rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--muted-strong);font-weight:600;margin-bottom:0.55rem;}
.daytype-pills{display:grid;grid-template-columns:repeat(4,1fr);gap:0.35rem;}
.daytype-pill{background:rgba(255,252,244,0.7);border:1.5px solid var(--border);border-radius:10px;padding:0.55rem 0.3rem;font-family:'DM Mono',monospace;cursor:pointer;text-align:center;transition:all 0.15s;display:flex;flex-direction:column;align-items:center;gap:0.15rem;}
.daytype-pill:hover{border-color:var(--sage);}
.daytype-pill.active{background:var(--sage);border-color:var(--sage-deep);}
.daytype-pill.active .dp-name{color:white;}
.daytype-pill.active .dp-sub{color:rgba(255,255,255,0.85);}
.dp-name{font-size:0.6rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink);font-weight:600;}
.dp-sub{font-size:0.5rem;color:var(--muted-strong);font-weight:500;}
.exercise{display:flex;align-items:flex-start;gap:0.8rem;padding:0.8rem 0;border-bottom:1px solid var(--border);}
.exercise:last-of-type{border-bottom:none;}
.ex-check{width:22px;height:22px;border:1.5px solid var(--border-strong);border-radius:6px;flex-shrink:0;background:transparent;cursor:pointer;position:relative;margin-top:0.15rem;}
.ex-check.done{background:var(--sage);border-color:var(--sage);}
.ex-check.done::after{content:'\2713';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:white;font-size:0.85rem;}
.ex-body{flex:1;min-width:0;}
.ex-name{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--sage-deep);}
.ex-detail{font-size:0.7rem;color:var(--ink-soft);margin-top:0.2rem;line-height:1.55;font-weight:400;}
.ex-target{font-size:0.55rem;color:var(--rose-dust);letter-spacing:0.08em;text-transform:uppercase;margin-top:0.25rem;}
.ex-meta-row{display:flex;flex-wrap:wrap;gap:0.3rem;align-items:center;margin-top:0.4rem;}
.swap-btn{background:transparent;border:1px solid var(--border-strong);color:var(--sage-deep);border-radius:6px;padding:0.25rem 0.55rem;font-family:'DM Mono',monospace;font-size:0.5rem;letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;}
.swap-btn.active{background:rgba(164,184,160,0.2);}
.input-inline{width:70px;background:rgba(255,252,244,0.7);border:1px solid var(--border-strong);border-radius:8px;padding:0.35rem 0.5rem;font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--ink);outline:none;}
.input-unit{font-size:0.5rem;letter-spacing:0.15em;color:var(--muted);text-transform:uppercase;}
.stats-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.5rem;margin-bottom:1rem;}
.stat-mini{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:0.85rem 0.8rem;text-align:center;}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:1.7rem;color:var(--sage-deep);font-weight:500;line-height:1;}
.stat-num .frac{font-size:0.85rem;color:var(--muted);}
.stat-lbl{font-size:0.52rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--muted-strong);margin-top:0.4rem;font-weight:500;}
.form-group{margin-bottom:1.1rem;}
.form-label{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--sage-deep);margin-bottom:0.3rem;display:block;}
.form-hint{font-size:0.64rem;color:var(--muted-strong);margin-bottom:0.5rem;letter-spacing:0.03em;line-height:1.55;font-weight:400;}
.input-row{display:flex;gap:0.5rem;align-items:center;}
.fg-input{flex:1;background:rgba(255,252,244,0.7);border:1px solid var(--border-strong);border-radius:10px;padding:0.7rem 0.85rem;font-family:'DM Mono',monospace;font-size:0.85rem;color:var(--ink);outline:none;transition:border-color 0.2s;min-width:0;}
.fg-input:focus{border-color:var(--sage);background:white;}
.fg-unit{font-size:0.6rem;color:var(--muted);letter-spacing:0.1em;min-width:44px;}
.score-badge{min-width:60px;text-align:center;font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--sage-deep);background:rgba(164,184,160,0.2);border:1px solid var(--border-strong);border-radius:10px;padding:0.45rem 0.6rem;font-weight:500;}
.pullup-stage-select{width:100%;background:rgba(255,252,244,0.7);border:1px solid var(--border-strong);border-radius:10px;padding:0.65rem 0.85rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:var(--ink);margin-bottom:0.5rem;}
.btn{width:100%;background:linear-gradient(135deg,var(--sage),var(--sage-deep));color:white;border:none;border-radius:12px;padding:0.9rem;font-family:'DM Mono',monospace;font-size:0.62rem;letter-spacing:0.3em;text-transform:uppercase;cursor:pointer;margin-top:0.5rem;font-weight:500;}
.btn:active{transform:scale(0.98);}
.btn:disabled{opacity:0.4;cursor:not-allowed;}
.btn.secondary{background:transparent;color:var(--sage-deep);border:1px solid var(--border-strong);}
.total-score{text-align:center;padding:1.4rem 1rem;background:linear-gradient(135deg,rgba(93,122,90,0.1),rgba(168,133,66,0.08));border-radius:14px;margin-top:1rem;border:1px solid var(--border-strong);}
.total-num{font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--sage-deep);font-weight:500;line-height:1;}
.total-max{font-size:0.9rem;color:var(--muted);}
.total-lbl{font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);margin-top:0.3rem;}
.tier-pill{display:inline-block;margin-top:0.6rem;font-size:0.55rem;letter-spacing:0.2em;padding:0.3rem 0.85rem;border-radius:999px;text-transform:uppercase;}
.tier-pill.foundation{background:rgba(163,160,154,0.15);color:var(--t-foundation);border:1px solid rgba(163,160,154,0.35);}
.tier-pill.solid{background:rgba(141,155,135,0.15);color:var(--t-solid);border:1px solid rgba(141,155,135,0.4);}
.tier-pill.strong{background:rgba(93,122,90,0.15);color:var(--t-strong);border:1px solid rgba(93,122,90,0.4);}
.tier-pill.decathlon{background:rgba(168,133,66,0.15);color:var(--t-decathlon);border:1px solid rgba(168,133,66,0.4);}
.tier-pill.centenarian{background:rgba(138,106,48,0.18);color:var(--t-centenarian);border:1px solid rgba(138,106,48,0.45);}
.tier-row{display:grid;grid-template-columns:repeat(5,1fr);gap:0.35rem;margin-top:0.7rem;}
.tier-chip{border-radius:10px;padding:0.65rem 0.3rem;text-align:center;border:1px solid transparent;}
.tier-chip.foundation{background:rgba(163,160,154,0.1);border-color:rgba(163,160,154,0.3);}
.tier-chip.solid{background:rgba(141,155,135,0.1);border-color:rgba(141,155,135,0.35);}
.tier-chip.strong{background:rgba(93,122,90,0.12);border-color:rgba(93,122,90,0.4);}
.tier-chip.decathlon{background:rgba(168,133,66,0.12);border-color:rgba(168,133,66,0.4);}
.tier-chip.centenarian{background:rgba(138,106,48,0.14);border-color:rgba(138,106,48,0.45);}
.tier-label{font-size:0.5rem;letter-spacing:0.13em;text-transform:uppercase;color:var(--muted-strong);margin-bottom:0.3rem;font-weight:600;}
.tier-chip.strong .tier-label{color:var(--sage-deep);font-weight:700;}
.tier-pts{font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--ink);font-weight:500;line-height:1;}
.tier-desc{font-size:0.52rem;color:var(--muted-strong);line-height:1.4;margin-top:0.3rem;font-weight:500;}
.score-event{padding:1rem 0;border-bottom:1px solid var(--border);}
.score-event:last-child{border-bottom:none;}
.se-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.4rem;}
.se-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--sage-deep);}
.se-pts{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--ink);font-weight:500;}
.se-detail{font-size:0.66rem;color:var(--muted-strong);margin-bottom:0.5rem;font-weight:500;}
.progress-track{position:relative;height:9px;background:rgba(125,151,120,0.12);border-radius:5px;overflow:visible;margin-bottom:0.4rem;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--sage-pale),var(--sage));border-radius:5px;transition:width 0.5s ease;}
.progress-marker{position:absolute;top:-2px;height:13px;width:2px;border-radius:1px;pointer-events:none;}
.progress-marker.solid{background:var(--t-solid);left:30%;}
.progress-marker.strong{background:var(--t-strong);left:60%;}
.progress-marker.decathlon{background:var(--t-decathlon);left:80%;}
.progress-marker.centenarian{background:var(--t-centenarian);left:95%;}
.sparkline{margin-top:0.5rem;height:28px;width:100%;}
.spark-empty{font-size:0.55rem;color:var(--muted);font-style:italic;margin-top:0.3rem;}
.history-item{padding:0.85rem 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:0.8rem;}
.history-item:last-child{border-bottom:none;}
.hi-date{font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:var(--sage-deep);}
.hi-note{font-size:0.6rem;color:var(--muted-strong);margin-top:0.15rem;font-weight:500;}
.hi-score{font-family:'Cormorant Garamond',serif;font-size:1.25rem;color:var(--ink);font-weight:500;}
.maint-toggle{margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);display:none;}
.maint-row{display:flex;justify-content:space-between;align-items:center;gap:0.8rem;}
.maint-info{flex:1;}
.maint-title{font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:var(--sage-deep);}
.maint-msg{font-size:0.66rem;color:var(--muted-strong);margin-top:0.2rem;line-height:1.5;font-weight:500;}
.custom-workout-form{display:none;margin-top:0.5rem;}
.custom-workout-form.active{display:block;}
.custom-workout-form input,.custom-workout-form textarea{width:100%;background:rgba(255,252,244,0.7);border:1px solid var(--border-strong);border-radius:10px;padding:0.65rem 0.85rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:var(--ink);outline:none;margin-bottom:0.5rem;}
.custom-workout-form textarea{resize:vertical;min-height:70px;}
.mode-toggle-row{display:flex;gap:0.5rem;margin-top:0.7rem;padding-top:0.8rem;border-top:1px solid var(--border);}
.mode-btn{flex:1;background:transparent;border:1px solid var(--border-strong);color:var(--muted);border-radius:8px;padding:0.55rem;font-family:'DM Mono',monospace;font-size:0.52rem;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;}
.mode-btn.active{background:rgba(164,184,160,0.2);color:var(--sage-deep);border-color:var(--sage);}
.sheet-overlay{position:fixed;inset:0;background:rgba(42,42,38,0.45);backdrop-filter:blur(4px);z-index:200;display:none;align-items:flex-end;}
.sheet-overlay.active{display:flex;}
.sheet{background:var(--cream);border-radius:20px 20px 0 0;width:100%;max-width:560px;margin:0 auto;padding:1.4rem 1.25rem 2rem;max-height:80vh;overflow-y:auto;border-top:1px solid var(--border-strong);}
.sheet-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
.sheet-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--sage-deep);}
.sheet-close{background:transparent;border:none;font-size:1.6rem;color:var(--muted);cursor:pointer;line-height:1;padding:0.2rem 0.5rem;}
.sub-option{border:1px solid var(--border);border-radius:12px;padding:0.85rem 1rem;margin-bottom:0.5rem;cursor:pointer;transition:all 0.15s;}
.sub-option:hover{border-color:var(--sage);background:rgba(164,184,160,0.08);}
.sub-option.selected{border-color:var(--sage);background:rgba(164,184,160,0.15);}
.sub-name{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--sage-deep);margin-bottom:0.2rem;}
.sub-note{font-size:0.66rem;color:var(--muted-strong);line-height:1.55;font-weight:500;}
.toast{position:fixed;bottom:85px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--sage-deep);color:white;padding:0.75rem 1.5rem;border-radius:999px;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;opacity:0;transition:all 0.3s;z-index:300;pointer-events:none;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.empty{text-align:center;color:var(--muted);font-size:0.7rem;font-style:italic;padding:1.5rem 0;}
</style>
</head>
<body>

<div class="app">

<header>
<div class="wordmark">VESPER</div>
<div class="tagline">The long watch &middot; still moving at 100</div>
</header>

<div class="view active" id="view-today">

<div class="checkin-banner" id="checkin-banner">
<div class="checkin-title">Check-in time</div>
<div class="checkin-text" id="checkin-text">It's been 4 weeks since your last calibration.</div>
<div class="checkin-actions">
<button id="checkin-snooze">Snooze 1 week</button>
<button id="checkin-done" class="primary">I've checked in</button>
</div>
</div>

<div class="stats-row">
<div class="stat-mini"><div class="stat-num" id="streak">0</div><div class="stat-lbl">Day Streak</div></div>
<div class="stat-mini"><div class="stat-num"><span id="train-week">0</span><span class="frac">/4</span></div><div class="stat-lbl">Push &middot; This Week</div></div>
<div class="stat-mini"><div class="stat-num" id="weeks-since-checkin">0</div><div class="stat-lbl">Wks &middot; Last Cal</div></div>
</div>

