// ===== RESTORE STATE =====
function restoreTodayState(){
  const todayRec=loadTodayRecovery();
  const todayWk=loadTodayWorkout();
  if(todayRec){
    currentRecovery=todayRec.color;
    document.querySelectorAll('.rec-btn').forEach(b=>b.classList.toggle('selected',b.dataset.rec===currentRecovery));
  }
  if(todayWk){
    currentSessionType=todayWk.sessionType||'training';
    currentDayType=todayWk.dayType||(currentRecovery==='travel'?'travel':suggestedDayType());
    currentMode=todayWk.mode||'prescribed';
  }else if(currentRecovery){
    currentDayType=currentRecovery==='travel'?'travel':suggestedDayType();
  }
  if(currentRecovery){
    generateWorkout();refreshMaintenanceToggle();
    if(currentMode==='custom')setModeUI('custom');
  }
}


