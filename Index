// ===== SCORES VIEW =====
function renderScores(){
  const tests=loadRecords('tests').sort((a,b)=>a.date.localeCompare(b.date));
  const latest=tests[tests.length-1];
  const el=document.getElementById('event-scores');
  if(!latest){el.innerHTML='<div class="empty">No tests logged yet \u2014 your scored events will appear here once you have a baseline.</div>';return;}
  const events=[
    {name:'1-Mile Run',score:latest.sMile,raw:latest.mileSec?secToStr(latest.mileSec):null,unit:'',trendKey:'sMile'},
    {name:'VO2 Max',score:latest.sVO2,raw:latest.vo2,unit:'ml/kg',trendKey:'sVO2'},
    {name:'Pull-Ups',score:latest.sPull,raw:latest.pullupReps!=null?(latest.pullupReps+' strict'+(latest.poseyStage?' \u00b7 Posey '+latest.poseyStage:'')):null,unit:'',trendKey:'sPull'},
    {name:'Goblet Squat',score:latest.sGob,raw:latest.goblet,unit:'reps @ 70lb',trendKey:'sGob'},
    {name:"Farmer's Carry",score:latest.sCar,raw:latest.carry,unit:'lb/hand',trendKey:'sCar'},
    {name:'Sit-Rise Test',score:latest.sSRT,raw:latest.srt,unit:'/10',trendKey:'sSRT'}
  ];
  el.innerHTML=events.map(e=>{
    const score=e.score||0;
    const tier=tierOf(e.score);
    const fillPct=Math.min(100,score);
    const sparkline=renderSparkline(tests,e.trendKey);
    return '<div class="score-event"><div class="se-head"><div class="se-name">'+e.name+'</div><div class="se-pts">'+(e.score==null?'\u2014':e.score)+'<span style="font-size:0.65rem;color:var(--muted);"> / 100</span></div></div><div class="se-detail">'+(e.raw!=null?escapeHTML(String(e.raw))+' '+e.unit:'Not yet tested')+' \u00b7 <span class="tier-pill '+tier+'" style="display:inline-block;margin:0;font-size:0.5rem;padding:0.15rem 0.5rem;">'+tierLabel(tier)+'</span></div><div class="progress-track"><div class="progress-fill" style="width:'+fillPct+'%;"></div><div class="progress-marker solid"></div><div class="progress-marker strong"></div><div class="progress-marker decathlon"></div><div class="progress-marker centenarian"></div></div>'+sparkline+'</div>';
  }).join('');
}

function renderSparkline(tests,key){
  const data=tests.map(t=>t[key]).filter(v=>v!=null);
  if(data.length<2)return '<div class="spark-empty">Trend appears after 2+ tests</div>';
  const w=280,h=28;
  const pts=data.map((v,i)=>{const x=(i/(data.length-1))*w;const y=h-((v-0)/100)*h;return x.toFixed(1)+','+y.toFixed(1);});
  const path='M '+pts.join(' L ');
  const last=data[data.length-1];const first=data[0];const delta=last-first;
  return '<svg class="sparkline" viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="none"><path d="'+path+'" fill="none" stroke="var(--sage)" stroke-width="1.5" />'+pts.map(p=>{const[x,y]=p.split(',');return '<circle cx="'+x+'" cy="'+y+'" r="1.8" fill="var(--sage-deep)" />';}).join('')+'</svg><div style="font-size:0.5rem;color:var(--muted);letter-spacing:0.1em;margin-top:0.2rem;">'+data.length+' tests \u00b7 '+(delta>=0?'\u0394 +'+delta:'\u0394 '+delta)+' pts since first</div>';
}

