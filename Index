  return{strength:'~45 min \u00b7 DBs, pull-up progression, carries',cardio:'~30 min \u00b7 intervals or Z2 (climbing-gym friendly)',adventure:'60\u2013120 min \u00b7 hike, climb, long ride, long run',maintenance:'~25 min \u00b7 walk + mobility'}[t]||'';
}

