function saveTodayRecovery(color){
  const today=todayStr();
  const existing=loadTodayRecovery();
  if(existing)updateRecord('recovery',existing._id,{color,date:today});
  else saveRecord('recovery',{color,date:today});
}

function refreshMaintenanceToggle(){
  const wrap=document.getElementById('maint-toggle');
  const btn=document.getElementById('maint-btn');
  const msg=document.getElementById('maint-msg');
  if(!currentRecovery||currentRecovery==='red'||currentRecovery==='travel'){wrap.style.display='none';return;}
  wrap.style.display='block';
  const used=maintenanceUsedThisWeek();
  const remaining=MAINT_CAP-used;
  if(currentSessionType==='maintenance'){
    btn.textContent='Switch to Push';
    btn.disabled=false;
    msg.innerHTML='<strong style="color:var(--sage-deep);">Maintenance day active.</strong> '+(remaining>0?remaining+' remaining':'last one')+' this week.';
  }else if(remaining<=0){
    btn.textContent='Cap reached';btn.disabled=true;
    msg.innerHTML='<strong style="color:var(--sage-deep);">'+MAINT_CAP+'/'+MAINT_CAP+' maintenance days used.</strong> Resets Monday.';
  }else{
    btn.textContent='Use Maintenance';btn.disabled=false;
    msg.textContent=remaining+' of '+MAINT_CAP+' maintenance days available this week (Mon\u2013Sun). Red & travel days don\u2019t count.';
  }
}

document.getElementById('maint-btn').addEventListener('click',()=>{
  if(currentSessionType==='maintenance'){
    currentSessionType='training';
    currentDayType=currentRecovery==='travel'?'travel':suggestedDayType();
    persistSessionType(false,suggestedDayType());generateWorkout();showToast('Switched to push day');
  }else{
    if(maintenanceUsedThisWeek()>=MAINT_CAP){showToast('Maintenance cap reached');return;}
    currentSessionType='maintenance';currentDayType='maintenance';
    const suggested=suggestedDayType();
    persistSessionType(suggested!=='maintenance',suggested);generateWorkout();showToast('Maintenance day \u00b7 lighter prescription');
  }
  refreshMaintenanceToggle();
});

function persistSessionType(isDeviation,suggestedType){
  const today=todayStr();
  const existing=loadTodayWorkout();
  const record={...(existing||{}),date:today,recovery:currentRecovery,sessionType:currentSessionType,dayType:currentDayType,suggestedDayType:suggestedType||suggestedDayType(),dayTypeChanged:!!isDeviation,completedExercises:existing?.completedExercises||[],lastUpdated:new Date().toISOString()};
  if(existing&&existing._id)updateRecord('workouts',existing._id,record);
  else saveRecord('workouts',record);
}

// ===== GENERATE WORKOUT =====
function getWorkoutTemplate(){
  if(currentSessionType==='maintenance'){
    const intensity=(currentRecovery==='red')?'red':(currentRecovery==='yellow'?'yellow':'green');
    return WORKOUTS.maintenance[intensity];
  }
  if(currentRecovery==='travel')return WORKOUTS.travel;
  if(currentRecovery==='red')return WORKOUTS[currentDayType]?.red||WORKOUTS.maintenance.red;
  const intensity=currentRecovery==='yellow'?'yellow':'green';
  return WORKOUTS[currentDayType]?.[intensity]||WORKOUTS.strength.green;
}

function generateWorkout(){
  const w=getWorkoutTemplate();
  if(!w)return;
  document.getElementById('primer-text').textContent=pickPrimer(currentRecovery||'green');
  document.getElementById('primer-card').style.display='block';
  const labelEl=document.getElementById('workout-label');
  if(currentSessionType==='maintenance')labelEl.innerHTML='<span style="color:var(--sage);">Maintenance \u00b7 Light prescription</span>';
  else if(currentRecovery==='travel')labelEl.innerHTML='<span style="color:var(--travel);">Travel Day</span>';
  else labelEl.textContent="Today's Work";
  document.getElementById('workout-title').textContent=w.title;
  const suggested=suggestedDayType();
  const isDeviation=(currentDayType!==suggested&&currentRecovery!=='travel'&&currentSessionType!=='maintenance');
  let badgeText=(DAYTYPE_LABELS[currentDayType]||'Session')+' \u00b7 '+(currentRecovery||'green').toUpperCase();
  if(isDeviation)badgeText+=' \u00b7 SWAPPED FROM '+DAYTYPE_LABELS[suggested].toUpperCase();
  document.getElementById('workout-type-badge').textContent=badgeText;

  // Day-type pill row visibility + active state
  const dtRow=document.getElementById('daytype-row');
  if(currentRecovery==='travel'||currentRecovery==='red'){
    dtRow.style.display='none';
  }else{
    dtRow.style.display='block';
    document.querySelectorAll('.daytype-pill').forEach(p=>{
      const active=(currentSessionType==='maintenance'&&p.dataset.daytype==='maintenance')||
                   (currentSessionType!=='maintenance'&&p.dataset.daytype===currentDayType);
      p.classList.toggle('active',active);
    });
  }

  const list=document.getElementById('workout-list');
  list.innerHTML='';
  const existing=loadTodayWorkout();
  const doneSet=new Set(existing?.completedExercises||[]);
  const weights=existing?.exerciseWeights||{};
  const subs=existing?.substitutions||{};
  w.exercises.forEach(ex=>list.appendChild(renderExerciseRow(ex,doneSet.has(ex.name),weights[ex.name],subs[ex.name])));
  document.getElementById('workout-card').style.display='block';
  setModeUI('prescribed');
}

function renderExerciseRow(ex,isDone,weight,sub){
  const row=document.createElement('div');
  row.className='exercise';
  const displayName=sub?.name||ex.name;
  const displayDetail=sub?.note||ex.detail;
  const hasSubsAvailable=SUBSTITUTIONS[ex.category]?.length>0;
  row.innerHTML=
    '<div class="ex-check '+(isDone?'done':'')+'" data-name="'+escapeHTML(ex.name)+'"></div>'+
    '<div class="ex-body">'+
    '<div class="ex-name">'+escapeHTML(displayName)+(sub?' <span style="font-size:0.5rem;color:var(--rose-dust);letter-spacing:0.15em;">SWAPPED</span>':'')+'</div>'+
    '<div class="ex-detail">'+escapeHTML(displayDetail)+'</div>'+
    (ex.target?'<div class="ex-target">'+escapeHTML(ex.target)+(ex.event?' \u00b7 '+escapeHTML(ex.event):'')+'</div>':'')+
    (ex.trackWeight?'<div class="ex-meta-row"><input type="number" class="input-inline weight-input" data-name="'+escapeHTML(ex.name)+'" value="'+(weight||'')+'" placeholder="lbs" inputmode="numeric"><span class="input-unit">lbs used</span></div>':'')+
    (hasSubsAvailable?'<div class="ex-meta-row"><button class="swap-btn '+(sub?'active':'')+'" data-action="swap" data-name="'+escapeHTML(ex.name)+'" data-category="'+ex.category+'">'+(sub?'Swap':'Swap')+'</button>'+(sub?'<button class="swap-btn" data-action="reset" data-name="'+escapeHTML(ex.name)+'">Reset</button>':'')+'</div>':'')+
    '</div>';
  row.querySelector('.ex-check').addEventListener('click',()=>{
    row.querySelector('.ex-check').classList.toggle('done');
    autoSaveProgress();
  });
  const wi=row.querySelector('.weight-input');
  if(wi)wi.addEventListener('input',()=>autoSaveProgress());
  row.querySelectorAll('.swap-btn').forEach(b=>{
    b.addEventListener('click',()=>{
      if(b.dataset.action==='swap')openSwapSheet(b.dataset.name,b.dataset.category);
      else if(b.dataset.action==='reset')resetSwap(b.dataset.name);
    });
  });
  return row;
}

// ===== AUTO-SAVE =====
function autoSaveProgress(){
  const today=todayStr();
  const existing=loadTodayWorkout();
  const w=getWorkoutTemplate();
  const completedNames=[];
  document.querySelectorAll('.ex-check').forEach(c=>{if(c.classList.contains('done'))completedNames.push(c.dataset.name);});
  const exerciseWeights={...(existing?.exerciseWeights||{})};
  document.querySelectorAll('.weight-input').forEach(inp=>{
    const v=parseFloat(inp.value);
    if(!isNaN(v)&&v>0)exerciseWeights[inp.dataset.name]=v;
  });
  const totalChecks=document.querySelectorAll('.ex-check').length;
  const record={...(existing||{}),date:today,recovery:currentRecovery,sessionType:currentSessionType,dayType:currentDayType,mode:'prescribed',workoutTitle:w?.title||'',completedExercises:completedNames,exerciseWeights,completed:completedNames.length,total:totalChecks,lastUpdated:new Date().toISOString()};
  if(existing&&existing._id)updateRecord('workouts',existing._id,record);
  else saveRecord('workouts',record);
  updateHeaderStats();
}

// ===== SWAP SHEET =====
const subSheet=document.getElementById('sub-sheet');
document.getElementById('sheet-close').addEventListener('click',()=>subSheet.classList.remove('active'));
subSheet.addEventListener('click',e=>{if(e.target===subSheet)subSheet.classList.remove('active');});

function openSwapSheet(originalName,category){
  const opts=SUBSTITUTIONS[category]||[];
  document.getElementById('sheet-title').textContent='Swap "'+originalName+'"';
  const content=document.getElementById('sheet-content');
  content.innerHTML=opts.map(opt=>'<div class="sub-option" data-name="'+escapeHTML(opt.name)+'"><div class="sub-name">'+escapeHTML(opt.name)+'</div><div class="sub-note">'+escapeHTML(opt.note)+'</div></div>').join('');
  content.querySelectorAll('.sub-option').forEach(el=>{
    el.addEventListener('click',()=>{applySwap(originalName,opts.find(o=>o.name===el.dataset.name));subSheet.classList.remove('active');});
  });
  subSheet.classList.add('active');
}

function applySwap(originalName,sub){
  const existing=loadTodayWorkout();
  const subs={...(existing?.substitutions||{})};
  subs[originalName]=sub;
  const completed=(existing?.completedExercises||[]).filter(n=>n!==originalName);
  const record={...(existing||{}),date:todayStr(),recovery:currentRecovery,sessionType:currentSessionType,dayType:currentDayType,substitutions:subs,completedExercises:completed,lastUpdated:new Date().toISOString()};
  if(existing&&existing._id)updateRecord('workouts',existing._id,record);
  else saveRecord('workouts',record);
  showToast('Swap applied');generateWorkout();
}

function resetSwap(originalName){
  const existing=loadTodayWorkout();
  const subs={...(existing?.substitutions||{})};
  delete subs[originalName];
  const record={...(existing||{}),date:todayStr(),substitutions:subs,lastUpdated:new Date().toISOString()};
  if(existing&&existing._id)updateRecord('workouts',existing._id,record);
  else saveRecord('workouts',record);
  showToast('Reset to original');generateWorkout();
}

// ===== DAY-TYPE PILL ROW (inline switcher) =====
document.querySelectorAll('.daytype-pill').forEach(pill=>{
  pill.addEventListener('click',()=>{
    if(!currentRecovery){showToast('Tap a recovery color first');return;}
    if(currentRecovery==='travel'){showToast('Travel day uses bodyweight protocol');return;}
    const newType=pill.dataset.daytype;
    if(newType===currentDayType&&currentSessionType!=='maintenance')return;
    const suggested=suggestedDayType();
    const isDeviation=(newType!==suggested);
    currentDayType=newType;
    currentSessionType=(newType==='maintenance')?'maintenance':'training';
    if(currentSessionType==='maintenance'&&maintenanceUsedThisWeek()>=MAINT_CAP){
      showToast('Maintenance cap reached this week');
      currentSessionType='training';currentDayType=suggested;
      return;
    }
    persistSessionType(isDeviation,suggested);
    generateWorkout();
    refreshMaintenanceToggle();
    showToast('Switched to '+DAYTYPE_LABELS[currentDayType]);
  });
});

