<script>
// ===== STORAGE =====
const LS_KEY='vesper_data_v1';
function loadAll(){try{return JSON.parse(localStorage.getItem(LS_KEY))||{};}catch(e){return{};}}
function saveAll(d){try{localStorage.setItem(LS_KEY,JSON.stringify(d));return true;}catch(e){return false;}}
function loadRecords(t){return(loadAll()[t]||[]).slice();}
function saveRecord(t,r){const a=loadAll();if(!a[t])a[t]=[];r._id=r._id||('r'+Date.now()+Math.random().toString(36).slice(2,8));r.createdAt=r.createdAt||new Date().toISOString();a[t].push(r);saveAll(a);return r;}
function updateRecord(t,id,patch){const a=loadAll();if(!a[t])return null;const i=a[t].findIndex(r=>r._id===id);if(i===-1)return null;a[t][i]={...a[t][i],...patch};saveAll(a);return a[t][i];}
function getSetting(k,fb){const a=loadAll();return(a._settings&&a._settings[k]!==undefined)?a._settings[k]:fb;}
function setSetting(k,v){const a=loadAll();if(!a._settings)a._settings={};a._settings[k]=v;saveAll(a);}

// ===== DATES =====
function todayStr(){return new Date().toISOString().slice(0,10);}
function thisWeekMonday(){const d=new Date();const day=d.getDay();const off=day===0?6:day-1;d.setDate(d.getDate()-off);return d.toISOString().slice(0,10);}
function dateInThisWeek(iso){return iso>=thisWeekMonday()&&iso<=todayStr();}
function daysBetween(a,b){return Math.floor((new Date(b)-new Date(a))/86400000);}
function formatDateShort(iso){return new Date(iso).toLocaleDateString('en-US',{month:'short',day:'numeric'});}
function formatDate(iso){return new Date(iso).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
function dayOfWeek(){return new Date().getDay();}
function parseTime(s){if(!s)return null;const m=String(s).match(/^(\d+):(\d+)$/);return m?parseInt(m[1])*60+parseInt(m[2]):null;}
function secToStr(s){if(s==null||isNaN(s))return '\u2014';const m=Math.floor(s/60),x=s%60;return m+':'+String(x).padStart(2,'0');}
function escapeHTML(s){return String(s||'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);}

// ===== SCORING =====
const MILE_TABLE=[[390,100],[405,97],[420,95],[435,92],[450,88],[465,84],[480,80],[495,75],[510,70],[525,65],[540,60],[555,55],[570,50],[585,45],[600,40],[615,35],[630,30],[645,25],[660,20],[690,10],[720,5],[780,0]];
function scoreMile(s){if(s==null||s<=0)return null;for(const[t,p]of MILE_TABLE)if(s<=t)return p;return 0;}
const VO2_TABLE=[[50,100],[47,98],[45,95],[43,92],[42,90],[40,88],[39,86],[38,85],[37,82],[36,78],[35,75],[34,70],[33,65],[32,60],[31,55],[30,50],[29,45],[28,40],[27,35],[26,30],[25,25],[24,20],[22,10],[20,5],[0,0]];
function scoreVO2(v){if(v==null||v<=0)return null;for(const[t,p]of VO2_TABLE)if(v>=t)return p;return 0;}
const PULLUP_TABLE=[[12,100],[10,98],[8,96],[7,94],[6,92],[5,90],[4,85],[3,80],[2,70],[1,60],[0,0]];
const POSEY_PTS=[0,15,25,30,38,45,52];
function scorePullup(reps,stage){let r=null;if(reps!=null&&reps>=0)for(const[t,p]of PULLUP_TABLE){if(reps>=t){r=p;break;}}let s=null;if(stage!=null&&stage>=0&&stage<=6)s=POSEY_PTS[stage]||0;if(r==null&&s==null)return null;return Math.max(r||0,s||0);}
const GOBLET_TABLE=[[35,100],[30,96],[27,92],[25,90],[22,86],[20,80],[18,75],[16,70],[14,65],[12,60],[10,50],[8,40],[6,30],[4,20],[2,10],[0,0]];
function scoreGoblet(r){if(r==null||r<0)return null;for(const[t,p]of GOBLET_TABLE)if(r>=t)return p;return 0;}
const CARRY_TABLE=[[90,100],[85,96],[80,92],[75,88],[70,82],[65,78],[60,72],[55,65],[50,58],[45,50],[40,42],[35,35],[30,28],[25,20],[20,12],[15,5],[0,0]];
function scoreCarry(p){if(p==null||p<0)return null;for(const[t,pt]of CARRY_TABLE)if(p>=t)return pt;return 0;}
